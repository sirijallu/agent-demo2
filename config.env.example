# Anthropic API key used by agent-demo2.py
# Get a key at https://console.anthropic.com/settings/keys
# Copy this file to config.env and fill in your real keys.
ANTHROPIC_API_KEY=your-api-key-here

# Voyage AI key for knowledge-base embeddings (Agentic RAG)
# Get a key at https://dashboard.voyageai.com/api-keys
VOYAGE_API_KEY=your-voyage-key-here

# Vercel Blob read-write token for the kb index (Vercel dashboard →
# agent-demo project → Storage → your Blob store → .env.local tab)
BLOB_READ_WRITE_TOKEN=your-blob-token-here
